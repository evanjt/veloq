{
  "name": "veloq",
  "version": "0.3.3",
  "repository": {
    "type": "git",
    "url": "https://github.com/evanjt/veloq"
  },
  "main": "expo-router/entry",
  "scripts": {
    "start": "npx expo start",
    "android": "npx expo run:android",
    "android:prod": "APP_VARIANT=production npx expo run:android --variant release",
    "ios": "npx expo run:ios",
    "ios:prod": "APP_VARIANT=production npx expo run:ios --configuration Release",
    "clean:rust": "npm run clean --prefix modules/veloqrs",
    "clean:rust:full": "npm run clean:full --prefix modules/veloqrs",
    "rebuild:android": "npm run clean:rust && npx expo run:android",
    "rebuild:android:prod": "npm run clean:rust && APP_VARIANT=production npx expo run:android --variant release",
    "rebuild:ios": "npm run clean:rust && npx expo run:ios",
    "rebuild:ios:prod": "npm run clean:rust && APP_VARIANT=production npx expo run:ios --configuration Release",
    "build:info": "cat modules/veloqrs/android/src/main/jniLibs/BUILD_INFO 2>/dev/null || echo 'No build info found'",
    "web": "npx expo start --web",
    "test": "jest --config config/jest.config.js",
    "test:watch": "jest --config config/jest.config.js --watch",
    "test:coverage": "jest --config config/jest.config.js --coverage",
    "test:perf": "jest --config config/jest.config.js --testPathPattern=perf.test --verbose",
    "test:perf:ci": "jest --config config/jest.config.js --testPathPattern=perf.test --json --outputFile=perf-results.json",
    "format": "prettier --config config/.prettierrc --ignore-path config/.prettierignore --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --config config/.prettierrc --ignore-path config/.prettierignore --check \"src/**/*.{ts,tsx}\"",
    "prepare": "husky",
    "postinstall": "node scripts/patch-expo-signing.js",
    "maestro:smoke": "maestro test .maestro/ --include-tags=tier0 --no-ansi",
    "maestro:test": "maestro test .maestro/ --include-tags=tier0,tier1,tier2 --no-ansi",
    "maestro:stress": "maestro test .maestro/ --include-tags=tier3 --no-ansi",
    "maestro:screenshots": "maestro test .maestro/ --include-tags=tier4 --no-ansi",
    "ffi:manifest": "npx tsx scripts/extract-ffi-exports.ts",
    "ffi:check": "npx tsx scripts/extract-ffi-exports.ts --check",
    "ffi:test": "jest --config config/jest.config.js --testPathPattern=ffiBinding",
    "ffi:usage": "npx tsx scripts/ffi-usage-report.ts",
    "ffi:unused": "npx tsx scripts/ffi-usage-report.ts --unused"
  },
  "dependencies": {
    "@expo/ngrok": "^4.1.3",
    "@expo/vector-icons": "^15.0.3",
    "@mapbox/polyline": "^1.2.1",
    "@maplibre/maplibre-react-native": "^10.4.2",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@shopify/react-native-skia": "2.4.18",
    "@tanstack/query-async-storage-persister": "^5.90.14",
    "@tanstack/react-query": "^5.90.12",
    "@tanstack/react-query-persist-client": "^5.90.14",
    "axios": "^1.15.0",
    "babel-preset-expo": "~55.0.7",
    "expo": "~55.0.19",
    "expo-blur": "~55.0.14",
    "expo-build-properties": "~55.0.13",
    "expo-camera": "~55.0.16",
    "expo-constants": "~55.0.15",
    "expo-crypto": "~55.0.14",
    "expo-document-picker": "~55.0.13",
    "expo-file-system": "~55.0.17",
    "expo-font": "~55.0.6",
    "expo-haptics": "~55.0.14",
    "expo-keep-awake": "~55.0.7",
    "expo-linear-gradient": "~55.0.13",
    "expo-linking": "~55.0.14",
    "expo-localization": "~55.0.13",
    "expo-location": "~55.1.8",
    "expo-network": "~55.0.13",
    "expo-notifications": "~55.0.22",
    "expo-router": "~55.0.13",
    "expo-screen-orientation": "~55.0.13",
    "expo-secure-store": "~55.0.13",
    "expo-sharing": "~55.0.18",
    "expo-status-bar": "~55.0.5",
    "expo-store-review": "~55.0.13",
    "expo-system-ui": "~55.0.16",
    "expo-task-manager": "~55.0.15",
    "expo-web-browser": "~55.0.14",
    "i18next": "^26.0.8",
    "intl-pluralrules": "^2.0.1",
    "jszip": "^3.10.1",
    "react": "19.2.0",
    "react-i18next": "^17.0.6",
    "react-native": "0.83.6",
    "react-native-body-highlighter": "^3.1.4",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-iap": "^15.2.0",
    "react-native-nitro-modules": "^0.35.6",
    "react-native-paper": "^5.14.5",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-webview": "13.16.0",
    "react-native-worklets": "0.7.4",
    "veloqrs": "./modules/veloqrs",
    "victory-native": "^41.20.2",
    "zod": "^4.3.5",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.1",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "29.5.14",
    "@types/react": "~19.2.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "babel-plugin-transform-remove-console": "^6.9.4",
    "glob": "^10.5.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-circus": "^30.2.0",
    "jest-expo": "~55.0.16",
    "lint-staged": "^16.2.7",
    "prettier": "^3.4.2",
    "react-dom": "19.2.0",
    "ts-jest": "^29.4.6",
    "typescript": "^6.0.3",
    "uniffi-bindgen-react-native": "^0.31.0-2"
  },
  "private": true,
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "prettier --config config/.prettierrc --ignore-path config/.prettierignore --write"
    ]
  }
}
