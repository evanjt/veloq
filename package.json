{
  "name": "veloq",
  "version": "0.4.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/evanjt/veloq"
  },
  "main": "expo-router/entry",
  "scripts": {
    "start": "npx expo start",
    "android": "npx expo run:android",
    "android:prod": "APP_VARIANT=production npx expo run:android --variant release",
    "ios": "npx expo run:ios",
    "ios:prod": "APP_VARIANT=production npx expo run:ios --configuration Release",
    "clean:rust": "npm run clean --prefix modules/veloqrs",
    "clean:rust:full": "npm run clean:full --prefix modules/veloqrs",
    "rebuild:android": "npm run clean:rust && npx expo run:android",
    "rebuild:android:prod": "npm run clean:rust && APP_VARIANT=production npx expo run:android --variant release",
    "rebuild:ios": "npm run clean:rust && npx expo run:ios",
    "rebuild:ios:prod": "npm run clean:rust && APP_VARIANT=production npx expo run:ios --configuration Release",
    "build:info": "cat modules/veloqrs/android/src/main/jniLibs/BUILD_INFO 2>/dev/null || echo 'No build info found'",
    "web": "npx expo start --web",
    "test": "jest --config config/jest.config.js",
    "test:watch": "jest --config config/jest.config.js --watch",
    "test:coverage": "jest --config config/jest.config.js --coverage",
    "test:perf": "jest --config config/jest.config.js --testPathPattern=perf.test --verbose",
    "test:perf:ci": "jest --config config/jest.config.js --testPathPattern=perf.test --json --outputFile=perf-results.json",
    "format": "prettier --config config/.prettierrc --ignore-path config/.prettierignore --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --config config/.prettierrc --ignore-path config/.prettierignore --check \"src/**/*.{ts,tsx}\"",
    "prepare": "husky",
    "postinstall": "node scripts/patch-expo-signing.js",
    "maestro:smoke": "maestro test .maestro/ --include-tags=tier0 --no-ansi",
    "maestro:gate": "maestro test .maestro/ --include-tags=tier0,tier1 --no-ansi",
    "maestro:test": "maestro test .maestro/ --include-tags=tier0,tier1,tier2 --no-ansi",
    "maestro:stress": "maestro test .maestro/ --include-tags=tier3 --no-ansi",
    "maestro:screenshots": "maestro test .maestro/ --include-tags=tier4 --no-ansi",
    "maestro:full": "maestro test .maestro/ --include-tags=tier0,tier1,tier2,tier3 --no-ansi",
    "maestro:pack:auth": "maestro test .maestro/ --include-tags=pack-auth --no-ansi",
    "maestro:pack:nav": "maestro test .maestro/ --include-tags=pack-nav --no-ansi",
    "maestro:pack:home": "maestro test .maestro/ --include-tags=pack-home --no-ansi",
    "maestro:pack:activity": "maestro test .maestro/ --include-tags=pack-activity --no-ansi",
    "maestro:pack:map": "maestro test .maestro/ --include-tags=pack-map --no-ansi",
    "maestro:pack:fitness": "maestro test .maestro/ --include-tags=pack-fitness --no-ansi",
    "maestro:pack:training": "maestro test .maestro/ --include-tags=pack-training --no-ansi",
    "maestro:pack:routes": "maestro test .maestro/ --include-tags=pack-routes --no-ansi",
    "maestro:pack:settings": "maestro test .maestro/ --include-tags=pack-settings --no-ansi",
    "maestro:pack:data": "maestro test .maestro/ --include-tags=pack-data --no-ansi",
    "maestro:pack:stress": "maestro test .maestro/ --include-tags=pack-stress --no-ansi",
    "ffi:manifest": "npx tsx scripts/extract-ffi-exports.ts",
    "ffi:check": "npx tsx scripts/extract-ffi-exports.ts --check",
    "ffi:test": "jest --config config/jest.config.js --testPathPattern=ffiBinding",
    "ffi:usage": "npx tsx scripts/ffi-usage-report.ts",
    "ffi:unused": "npx tsx scripts/ffi-usage-report.ts --unused",
    "gen:widget-theme": "npx tsx scripts/gen-widget-theme.ts",
    "check:expo": "node scripts/check-expo-sdk.mjs",
    "crash:guard": "node scripts/crash-guard-sweep.mjs",
    "lint:engine-bridge": "node scripts/engine-event-bridge-audit.mjs",
    "ffi:gate": "node scripts/ffi-timing-gate.mjs",
    "perf:coldstart": "node scripts/cold-start-scaling-harness.mjs",
    "audit": "npm run check:expo && npm run ffi:check && npm run crash:guard && npm run lint:engine-bridge"
  },
  "dependencies": {
    "@expo/ngrok": "^4.1.3",
    "@expo/vector-icons": "^15.0.3",
    "@mapbox/polyline": "^1.2.1",
    "@maplibre/maplibre-react-native": "^10.4.2",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/slider": "5.2.0",
    "@shopify/react-native-skia": "2.6.2",
    "@tanstack/query-async-storage-persister": "^5.90.14",
    "@tanstack/react-query": "^5.90.12",
    "@tanstack/react-query-persist-client": "^5.90.14",
    "@types/react": "~19.2.14",
    "axios": "^1.16.0",
    "babel-preset-expo": "~56.0.0",
    "d3-shape": "^3.2.0",
    "expo": "^56",
    "expo-blur": "~56.0.3",
    "expo-build-properties": "~56.0.16",
    "expo-camera": "~56.0.7",
    "expo-constants": "~56.0.16",
    "expo-crypto": "~56.0.4",
    "expo-document-picker": "~56.0.4",
    "expo-file-system": "~56.0.7",
    "expo-font": "~56.0.5",
    "expo-haptics": "~56.0.3",
    "expo-keep-awake": "~56.0.3",
    "expo-linear-gradient": "~56.0.4",
    "expo-linking": "~56.0.13",
    "expo-localization": "~56.0.6",
    "expo-location": "~56.0.15",
    "expo-network": "~56.0.4",
    "expo-notifications": "~56.0.15",
    "expo-router": "~56.2.8",
    "expo-screen-orientation": "~56.0.5",
    "expo-secure-store": "~56.0.4",
    "expo-sharing": "~56.0.15",
    "expo-status-bar": "~56.0.4",
    "expo-store-review": "~56.0.3",
    "expo-system-ui": "~56.0.5",
    "expo-task-manager": "~56.0.16",
    "expo-web-browser": "~56.0.5",
    "i18next": "^25.7.3",
    "intl-pluralrules": "^2.0.1",
    "jest-expo": "~56.0.4",
    "jszip": "^3.10.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-i18next": "^17.0.6",
    "react-native": "0.85.3",
    "react-native-ble-plx": "^3.5.1",
    "react-native-body-highlighter": "^3.1.4",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-iap": "^15.2.0",
    "react-native-nitro-modules": "^0.35.6",
    "react-native-paper": "^5.14.5",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-webview": "13.16.1",
    "react-native-worklets": "0.8.3",
    "typescript": "~6.0.3",
    "veloqrs": "./modules/veloqrs",
    "victory-native": "^41.20.2",
    "zod": "^4.3.5",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@expo/config-plugins": "^56.0.8",
    "@react-native/assets-registry": "^0.85.3",
    "@react-native/jest-preset": "^0.85.3",
    "@testing-library/react": "^16.3.2",
    "@testing-library/react-native": "^14.0.1",
    "@types/d3-shape": "^3.1.8",
    "@types/jest": "29.5.14",
    "@types/react": "~19.2.14",
    "babel-plugin-module-resolver": "^5.0.2",
    "babel-plugin-transform-remove-console": "^6.9.4",
    "fast-check": "^4.8.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-circus": "^30.2.0",
    "jest-expo": "~56.0.4",
    "lint-staged": "^16.2.7",
    "prettier": "^3.4.2",
    "react-dom": "19.2.3",
    "ts-jest": "^29.4.9",
    "typescript": "~6.0.3",
    "uniffi-bindgen-react-native": "^0.31.0-2"
  },
  "private": true,
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "prettier --config config/.prettierrc --ignore-path config/.prettierignore --write"
    ]
  },
  "overrides": {
    "expo-modules-core": "56.0.14",
    "js-yaml": "^4.3.0",
    "uuid": ">=11.1.1"
  }
}
