{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "types": ["jest", "node", "react"],
    "paths": {
      "@/*": ["src/*"],
      "@/api": ["src/api"],
      "@/theme": ["src/theme"],
      "@/i18n": ["src/i18n"]
    },
    "resolveJsonModule": true,
    "incremental": true,
    "tsBuildInfoFile": ".tsbuildinfo"
  },
  "include": [
    "app/**/*.ts",
    "app/**/*.tsx",
    "src/**/*.ts",
    "src/**/*.tsx",
    "modules/**/*.ts",
    "modules/**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ],
  "exclude": [
    "modules/veloqrs/rust/tracematch/web/**"
  ]
}
