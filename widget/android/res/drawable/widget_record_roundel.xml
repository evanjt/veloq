<?xml version="1.0" encoding="utf-8"?>
<!-- White record roundel: ring with a filled centre on the teal record surface. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
  <item>
    <shape android:shape="oval">
      <stroke android:width="3dp" android:color="@color/widget_record_foreground" />
    </shape>
  </item>
  <item
    android:top="10dp"
    android:bottom="10dp"
    android:left="10dp"
    android:right="10dp">
    <shape android:shape="oval">
      <solid android:color="@color/widget_record_foreground" />
    </shape>
  </item>
</layer-list>
