<?xml version="1.0" encoding="utf-8"?>
<!-- Record glyph: teal ring with a filled centre, used on the large dashboard footer. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
  <item>
    <shape android:shape="oval">
      <stroke android:width="2dp" android:color="@color/widget_primary" />
    </shape>
  </item>
  <item
    android:top="6dp"
    android:bottom="6dp"
    android:left="6dp"
    android:right="6dp">
    <shape android:shape="oval">
      <solid android:color="@color/widget_primary" />
    </shape>
  </item>
</layer-list>
