<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:orientation="vertical"
  android:padding="@dimen/widget_padding"
  android:background="@drawable/widget_background">

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="top">

    <LinearLayout
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:orientation="vertical">
      <TextView android:id="@+id/large_form_label"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:textSize="@dimen/widget_text_label" android:textColor="@color/widget_text_secondary"
        android:textAllCaps="true" android:letterSpacing="0.05" />
      <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="bottom">
        <TextView android:id="@+id/large_form_value"
          android:layout_width="wrap_content" android:layout_height="wrap_content"
          android:textSize="@dimen/widget_text_metric" android:textStyle="bold"
          android:textColor="@color/widget_text_primary" />
        <TextView android:id="@+id/large_form_trend"
          android:layout_width="wrap_content" android:layout_height="wrap_content"
          android:layout_marginStart="4dp"
          android:textSize="@dimen/widget_text_label" android:textColor="@color/widget_trend_flat" />
      </LinearLayout>
    </LinearLayout>

    <LinearLayout
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:orientation="vertical">
      <TextView android:id="@+id/large_fitness_label"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:textSize="@dimen/widget_text_label" android:textColor="@color/widget_text_secondary"
        android:textAllCaps="true" android:letterSpacing="0.05" />
      <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="bottom">
        <TextView android:id="@+id/large_fitness_value"
          android:layout_width="wrap_content" android:layout_height="wrap_content"
          android:textSize="@dimen/widget_text_metric" android:textStyle="bold"
          android:textColor="@color/widget_blue" />
        <TextView android:id="@+id/large_fitness_trend"
          android:layout_width="wrap_content" android:layout_height="wrap_content"
          android:layout_marginStart="4dp"
          android:textSize="@dimen/widget_text_label" android:textColor="@color/widget_trend_flat" />
      </LinearLayout>
    </LinearLayout>

    <LinearLayout
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:orientation="vertical">
      <TextView android:id="@+id/large_fatigue_label"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:textSize="@dimen/widget_text_label" android:textColor="@color/widget_text_secondary"
        android:textAllCaps="true" android:letterSpacing="0.05" />
      <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="bottom">
        <TextView android:id="@+id/large_fatigue_value"
          android:layout_width="wrap_content" android:layout_height="wrap_content"
          android:textSize="@dimen/widget_text_metric" android:textStyle="bold"
          android:textColor="@color/widget_fatigue" />
        <TextView android:id="@+id/large_fatigue_trend"
          android:layout_width="wrap_content" android:layout_height="wrap_content"
          android:layout_marginStart="4dp"
          android:textSize="@dimen/widget_text_label" android:textColor="@color/widget_trend_flat" />
      </LinearLayout>
    </LinearLayout>

    <TextView
      android:id="@+id/large_ramp"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:paddingStart="6dp"
      android:paddingEnd="6dp"
      android:paddingTop="2dp"
      android:paddingBottom="2dp"
      android:textSize="@dimen/widget_text_caption"
      android:textStyle="bold"
      android:textColor="@color/widget_text_secondary" />
  </LinearLayout>

  <ImageView
    android:id="@+id/large_sparkline"
    android:layout_width="match_parent"
    android:layout_height="60dp"
    android:layout_marginTop="@dimen/widget_gap"
    android:scaleType="fitXY"
    android:contentDescription="@null" />

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="@dimen/widget_gap"
    android:orientation="horizontal"
    android:gravity="center_vertical">

    <TextView
      android:id="@+id/large_weekly"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:maxLines="1"
      android:ellipsize="end"
      android:textSize="@dimen/widget_text_label"
      android:textColor="@color/widget_text_secondary" />

    <TextView
      android:id="@+id/large_weekly_delta"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginStart="6dp"
      android:textSize="@dimen/widget_text_caption"
      android:textStyle="bold"
      android:textColor="@color/widget_trend_flat" />
  </LinearLayout>

  <View
    android:layout_width="match_parent"
    android:layout_height="1dp"
    android:layout_marginTop="@dimen/widget_gap"
    android:background="@color/widget_border" />

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="@dimen/widget_gap"
    android:orientation="horizontal"
    android:gravity="center_vertical">

    <TextView
      android:id="@+id/large_activity_name"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:maxLines="1"
      android:ellipsize="end"
      android:textSize="@dimen/widget_text_value"
      android:textStyle="bold"
      android:textColor="@color/widget_text_primary" />

    <ImageView
      android:id="@+id/large_pr"
      android:layout_width="6dp"
      android:layout_height="6dp"
      android:layout_marginStart="4dp"
      android:src="@drawable/widget_pr_dot"
      android:contentDescription="@null" />
  </LinearLayout>

  <TextView
    android:id="@+id/large_activity_sub"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:maxLines="1"
    android:ellipsize="end"
    android:textSize="@dimen/widget_text_label"
    android:textColor="@color/widget_text_secondary" />

  <LinearLayout
    android:id="@+id/large_impact_row"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginTop="2dp"
    android:orientation="horizontal"
    android:gravity="center_vertical">

    <TextView
      android:id="@+id/large_impact_before"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:textSize="@dimen/widget_text_label"
      android:textStyle="bold"
      android:textColor="@color/widget_text_primary" />

    <TextView
      android:id="@+id/large_impact_arrow"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginStart="3dp"
      android:layout_marginEnd="3dp"
      android:text="→"
      android:textSize="@dimen/widget_text_label"
      android:textColor="@color/widget_text_secondary" />

    <TextView
      android:id="@+id/large_impact_after"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:textSize="@dimen/widget_text_label"
      android:textStyle="bold"
      android:textColor="@color/widget_text_primary" />

    <TextView
      android:id="@+id/large_impact_tss"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginStart="6dp"
      android:textSize="@dimen/widget_text_label"
      android:textColor="@color/widget_text_secondary" />
  </LinearLayout>

  <TextView
    android:id="@+id/large_impact"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="2dp"
    android:maxLines="2"
    android:textSize="@dimen/widget_text_label"
    android:textColor="@color/widget_primary" />

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="@dimen/widget_gap"
    android:orientation="horizontal"
    android:gravity="center_vertical">

    <TextView
      android:id="@+id/large_hrv_label"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:textSize="@dimen/widget_text_label"
      android:textColor="@color/widget_text_secondary" />

    <TextView
      android:id="@+id/large_hrv_value"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginStart="4dp"
      android:textSize="@dimen/widget_text_label"
      android:textStyle="bold"
      android:textColor="@color/widget_text_primary" />

    <TextView
      android:id="@+id/large_hrv_trend"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginStart="4dp"
      android:textSize="@dimen/widget_text_caption"
      android:textColor="@color/widget_trend_flat" />

    <TextView
      android:id="@+id/large_rhr_label"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginStart="@dimen/widget_gap"
      android:textSize="@dimen/widget_text_label"
      android:textColor="@color/widget_text_secondary" />

    <TextView
      android:id="@+id/large_rhr_value"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginStart="4dp"
      android:textSize="@dimen/widget_text_label"
      android:textStyle="bold"
      android:textColor="@color/widget_text_primary" />

    <TextView
      android:id="@+id/large_rhr_trend"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginStart="4dp"
      android:textSize="@dimen/widget_text_caption"
      android:textColor="@color/widget_trend_flat" />

    <View
      android:layout_width="0dp"
      android:layout_height="1dp"
      android:layout_weight="1" />

    <ImageView
      android:id="@+id/large_record"
      android:layout_width="20dp"
      android:layout_height="20dp"
      android:src="@drawable/widget_record_glyph"
      android:contentDescription="@null" />
  </LinearLayout>
</LinearLayout>
