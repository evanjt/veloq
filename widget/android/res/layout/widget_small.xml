<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:orientation="vertical"
  android:gravity="center"
  android:padding="@dimen/widget_padding"
  android:background="@drawable/widget_background">

  <TextView
    android:id="@+id/small_label"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:textSize="@dimen/widget_text_label"
    android:textColor="@color/widget_text_secondary"
    android:textAllCaps="true"
    android:letterSpacing="0.05" />

  <TextView
    android:id="@+id/small_value"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:textSize="@dimen/widget_text_hero"
    android:textStyle="bold"
    android:textColor="@color/widget_text_primary" />

  <TextView
    android:id="@+id/small_trend"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:textSize="@dimen/widget_text_value"
    android:textColor="@color/widget_trend_flat" />
</LinearLayout>
