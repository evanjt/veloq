<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:orientation="horizontal"
  android:padding="@dimen/widget_padding"
  android:background="@drawable/widget_background">

  <LinearLayout
    android:layout_width="0dp"
    android:layout_height="match_parent"
    android:layout_weight="1"
    android:orientation="vertical">

    <TextView
      android:id="@+id/med_form_label"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:textSize="@dimen/widget_text_label"
      android:textColor="@color/widget_text_secondary"
      android:textAllCaps="true"
      android:letterSpacing="0.05" />

    <LinearLayout
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:orientation="horizontal"
      android:gravity="bottom">

      <TextView
        android:id="@+id/med_form_value"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="@dimen/widget_text_metric"
        android:textStyle="bold"
        android:textColor="@color/widget_text_primary" />

      <TextView
        android:id="@+id/med_form_trend"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="6dp"
        android:textSize="@dimen/widget_text_label"
        android:textColor="@color/widget_trend_flat" />
    </LinearLayout>

    <TextView
      android:id="@+id/med_fitness"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginTop="@dimen/widget_gap"
      android:textSize="@dimen/widget_text_label"
      android:textColor="@color/widget_text_secondary" />
  </LinearLayout>

  <LinearLayout
    android:layout_width="0dp"
    android:layout_height="match_parent"
    android:layout_weight="1"
    android:orientation="vertical"
    android:gravity="end">

    <TextView
      android:id="@+id/med_activity_name"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:maxLines="1"
      android:ellipsize="end"
      android:textSize="@dimen/widget_text_value"
      android:textStyle="bold"
      android:textColor="@color/widget_text_primary" />

    <TextView
      android:id="@+id/med_activity_sub"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:maxLines="1"
      android:ellipsize="end"
      android:textSize="@dimen/widget_text_label"
      android:textColor="@color/widget_text_secondary" />

    <TextView
      android:id="@+id/med_impact"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginTop="@dimen/widget_gap"
      android:maxLines="2"
      android:textSize="@dimen/widget_text_label"
      android:textColor="@color/widget_primary" />
  </LinearLayout>
</LinearLayout>
