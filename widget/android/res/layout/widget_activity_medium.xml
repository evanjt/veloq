<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:id="@+id/act_root"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:orientation="horizontal"
  android:padding="@dimen/widget_padding"
  android:background="@drawable/widget_background">

  <ImageView
    android:id="@+id/act_preview"
    android:layout_width="0dp"
    android:layout_height="match_parent"
    android:layout_weight="1"
    android:scaleType="fitCenter"
    android:contentDescription="@null" />

  <LinearLayout
    android:layout_width="0dp"
    android:layout_height="match_parent"
    android:layout_weight="1"
    android:layout_marginStart="@dimen/widget_gap"
    android:orientation="vertical"
    android:gravity="center_vertical">

    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:orientation="horizontal"
      android:gravity="center_vertical">

      <TextView
        android:id="@+id/act_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:maxLines="2"
        android:ellipsize="end"
        android:textSize="@dimen/widget_text_value"
        android:textStyle="bold"
        android:textColor="@color/widget_text_primary" />

      <ImageView
        android:id="@+id/act_pr"
        android:layout_width="6dp"
        android:layout_height="6dp"
        android:layout_marginStart="4dp"
        android:src="@drawable/widget_pr_dot"
        android:contentDescription="@null" />
    </LinearLayout>

    <TextView
      android:id="@+id/act_sub"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:maxLines="2"
      android:ellipsize="end"
      android:textSize="@dimen/widget_text_label"
      android:textColor="@color/widget_text_secondary" />

    <TextView
      android:id="@+id/act_tss"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginTop="2dp"
      android:visibility="gone"
      android:textSize="@dimen/widget_text_label"
      android:textStyle="bold"
      android:textColor="@color/widget_text_primary" />
  </LinearLayout>
</LinearLayout>
