{
  "expo": {
    "name": "Veloq",
    "slug": "veloq",
    "version": "0.3.3",
    "scheme": "veloq",
    "orientation": "default",
    "icon": "./src/assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./src/assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#5B9BD5"
    },
    "ios": {
      "supportsTablet": true,
      "requireFullScreen": true,
      "bundleIdentifier": "com.veloq.app",
      "buildNumber": "22",
      "infoPlist": {
        "CFBundleDevelopmentRegion": "en-AU",
        "CFBundleLocalizations": [
          "en-AU",
          "en-US",
          "en-GB",
          "es",
          "fr"
        ],
        "NSLocationWhenInUseUsageDescription": "Veloq uses your location to display activity maps, track routes, and record fitness activities.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Veloq uses your location in the background to continue recording fitness activities when the app is not in the foreground.",
        "UIBackgroundModes": [
          "location",
          "fetch",
          "remote-notification"
        ],
        "ITSAppUsesNonExemptEncryption": false
      },
      "config": {
        "usesNonExemptEncryption": false
      },
      "associatedDomains": [
        "applinks:intervals.icu"
      ],
      "appStoreUrl": "https://apps.apple.com/us/app/veloq/id6757836732"
    },
    "android": {
      "package": "com.veloq.app",
      "playStoreUrl": "https://play.google.com/store/apps/details?id=com.veloq.app",
      "versionCode": 22,
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/adaptive-icon.png",
        "backgroundColor": "#5B9BD5"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION",
        "ACCESS_NETWORK_STATE",
        "ACCESS_WIFI_STATE",
        "INTERNET",
        "VIBRATE"
      ]
    },
    "web": {
      "favicon": "./src/assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "./src/plugins/with-gradle-repositories",
      "./src/plugins/with-release-signing",
      "./src/plugins/with-packaging-options",
      "./src/plugins/with-veloqrs",
      "./src/plugins/with-r8-config",
      "./src/plugins/with-maplibre-nil-safety",
      "./src/plugins/with-android-backup",
      "./src/plugins/with-icloud",
      "expo-router",
      [
        "expo-screen-orientation",
        {
          "initialOrientation": "DEFAULT"
        }
      ],
      "expo-localization",
      [
        "expo-location",
        {
          "isAndroidBackgroundLocationEnabled": false,
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      "@maplibre/maplibre-react-native",
      "expo-web-browser",
      "expo-secure-store",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./src/assets/icon.png",
          "color": "#FC4C02"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {},
          "ios": {
            "deploymentTarget": "15.1"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "f8cfc9cb-dda9-4d0a-a061-e2f01fb42c2f"
      }
    }
  }
}
